# Copy to .env and adjust for local runs or docker compose variable substitution.

# Browser-facing WebRTC base URL (must reach MediaMTX from the client machine).
MEDIAMTX_WEBRTC_BASE_URL=http://localhost:8889

# Basic Auth *usernames* sent by WHIP/WHEP clients (password is a short-lived token from POST /sessions).
WHIP_USERNAME=publisher
WHEP_USERNAME=viewer

# Redis TTL for session records and token validity (bcrypt hashes stored in Redis).
# Shorter is safer; default 1h.
MEDIAMTX_TOKEN_TTL=1h
# Optional: set SESSION_TTL instead to override token TTL (same Redis expiry).
# SESSION_TTL=2h

# Internal /internal/mediamtx/* caller IP allowlist (optional).
# When empty, only loopback + private networks (RFC1918 / ULA) may call internal routes (Docker bridge OK).
# INTERNAL_AUTH_ALLOWED_IPS=

# Optional: override MediaMTX image used by mediamtx/Dockerfile build arg.
# MEDIAMTX_IMAGE=bluenviron/mediamtx:1.17.1-ffmpeg
