# Public WHIP/WHEP base exposed to your client.
MEDIAMTX_WEBRTC_BASE_URL=http://localhost:8889

# Client credentials (must match mediamtx.yml)
WHIP_USERNAME=publisher
WHIP_PASSWORD=publisher-pass
WHEP_USERNAME=viewer
WHEP_PASSWORD=viewer-pass

# Worker mode: passthrough | soulx
WORKER_MODE=passthrough

# --- SoulX (only when using docker-compose.soulx.yml) ---
# SOULX_DRY_RUN=0
# SOULX_CKPT_DIR=/app/third_party/SoulX-FlashHead/models/SoulX-FlashHead-1_3B
# SOULX_WAV2VEC_DIR=/app/third_party/SoulX-FlashHead/models/wav2vec2-base-960h
# TORCHDYNAMO_DISABLE=1

# Internal worker credentials (must match mediamtx.yml)
WORKER_RTSP_USER=worker
WORKER_RTSP_PASS=worker-pass

# Session API runtime
SESSION_TTL=24h
REQUEST_TIMEOUT=5s
SHUTDOWN_TIMEOUT=10s
INTERNAL_AUTH_ALLOWED_IPS=127.0.0.1,::1,mediamtx
